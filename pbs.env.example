# Example Proxmox Backup Server configuration
# Add these to your stack.env file

# Required: PBS repository in format username@pbs@hostname:datastore
# Example: backup-user@pbs@192.168.1.100:immich-backups
PBS_REPOSITORY=

# Required: PBS password (or use PBS_PASSWORD_FILE for password file)
PBS_PASSWORD=

# Required: PBS server fingerprint (obtained during first connection)
# Get it by running: proxmox-backup-client snapshot list --repository <repository>
PBS_FINGERPRINT=

# Optional: Backup schedule in cron format (default: 0 2 * * * = daily at 2 AM)
# BACKUP_SCHEDULE=0 2 * * *

# Optional: Backup identifier name (default: immich-backup)
# BACKUP_NAME=immich-backup
